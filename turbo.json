{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV"],
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "AUTH_SECRET",
    "OPENAI_API_KEY",
    "FIRECRAWL_API_KEY",
    "GLM5_API_KEY",
    "GROQ_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "db:generate": {},
    "db:push": {},
    "storybook": {
      "persistent": true,
      "cache": false
    }
  }
}
