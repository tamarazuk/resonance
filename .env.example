# ============================================================
# Resonance Environment Variables
# ============================================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control - it contains secrets
# ============================================================

# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# PostgreSQL connection string
# For local Docker setup (default):
DATABASE_URL="postgresql://resonance:resonance_dev_password@localhost:5432/resonance_dev"

# For Neon (replace with your Neon connection string):
# DATABASE_URL="postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ============================================================
# AUTHENTICATION
# ============================================================

# Auth.js session encryption secret
# Generate a new secret with: openssl rand -hex 32
# Or use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="generate-a-random-32-byte-hex-string-here"

# ============================================================
# THIRD-PARTY API KEYS
# ============================================================

# OpenAI API Key
# Used for:
# - Structuring experiences into STAR format (gpt-4o)
# - Parsing job descriptions (gpt-4o)
# - Fit analysis and gap detection (gpt-4o)
# - Generating cover letters and tailored materials (gpt-4o)
# - Creating vector embeddings (text-embedding-3-small)
#
# Get your API key at: https://platform.openai.com/api-keys
# Pricing: https://openai.com/pricing
OPENAI_API_KEY="sk-proj-your-openai-api-key-here"

# Firecrawl API Key
# Used for:
# - Scraping job posting URLs
# - Handling JS rendering and anti-bot bypass
# - Extracting clean markdown from job pages
#
# Get your API key at: https://www.firecrawl.dev/
# Free tier available with limited requests
FIRECRAWL_API_KEY="fc-your-firecrawl-api-key-here"

# ============================================================
# OPTIONAL CONFIGURATION
# ============================================================

# Node environment (development, production, test)
# Defaults to development if not set
# NODE_ENV="development"

# Port for the development server
# Defaults to 3000 if not set
# PORT="3000"

# ============================================================
# SETUP INSTRUCTIONS
# ============================================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Generate AUTH_SECRET:
#    openssl rand -hex 32
#    (copy the output and paste it as AUTH_SECRET)
#
# 3. Get your OpenAI API key:
#    - Go to https://platform.openai.com/api-keys
#    - Create a new API key
#    - Paste it as OPENAI_API_KEY
#
# 4. Get your Firecrawl API key:
#    - Go to https://www.firecrawl.dev/
#    - Sign up for a free account
#    - Get your API key from the dashboard
#    - Paste it as FIRECRAWL_API_KEY
#
# 5. Start the database:
#    mise run setup
#
# 6. Start development:
#    mise run dev
#
# ============================================================
